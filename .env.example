# Copy to .env to override defaults locally.
# All variables are optional; defaults in code match docker-compose services.

FLYCHAIN_ENV=local
FLYCHAIN_CLICKHOUSE_URL=http://flychain:flychain@localhost:8123/flychain
FLYCHAIN_POSTGRES_URL=postgresql://flychain:flychain@localhost:5432/flychain
FLYCHAIN_REDIS_URL=redis://localhost:6379/0
FLYCHAIN_OLLAMA_URL=http://localhost:11434
FLYCHAIN_GATEWAY_URL=http://localhost:8080

# Optional - only needed if you want a cloud judge or to proxy upstream providers.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
